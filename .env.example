# Postgres por partes (recomendado). Prisma arma DATABASE_URL al arrancar.
DB_HOST=aws-0-ca-central-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.alqwmjifjjvqazaxncrx
DB_PASSWORD=YOUR_PASSWORD
DB_SCHEMA=cms
DB_SSLMODE=require
# Transaction pooler (evita EMAXCONNSESSION del modo Session)
DB_PGBOUNCER=true
DB_CONNECTION_LIMIT=5
# Migraciones Prisma usan Session en este puerto
DB_MIGRATE_PORT=5432
# Opcional: si defines DATABASE_URL completa, tiene prioridad solo si faltan DB_HOST/DB_USER.
# DATABASE_URL="postgresql://..."

JWT_SECRET="just-time-cms-dev-secret-change-me"
JWT_EXPIRES_IN="8h"
PORT=3002
ADMIN_EMAIL="admin@justtime.co"
ADMIN_PASSWORD="Admin123!"
ADMIN_NAME="Administrador CMS"
CORS_ORIGIN="http://localhost:5173"

# Media → GCS (prod). Sin GCS_BUCKET → disco local ./uploads
GCS_BUCKET=just-time-media-prod
GCS_PROJECT_ID=just-time-sas
GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/just-time-media-prod

# Firebase Admin — variables de entorno (recomendado en Cloud Run / Secret Manager).
# La private key va en una sola línea con \n escapados.
FIREBASE_PROJECT_ID=just-time-sas
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@just-time-sas.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Fallback local opcional (archivo JSON; no usar en prod)
# FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-adminsdk.json

# Reglas Firestore sugeridas (colección admin_notifications):
#   match /admin_notifications/{id} {
#     allow read, update: if request.auth != null;
#     allow create, delete: if false;
#   }
