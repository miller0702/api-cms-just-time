DATABASE_URL="postgresql://justtime:justtime@localhost:5433/justtime?schema=cms"
JWT_SECRET="just-time-cms-dev-secret-change-me"
JWT_EXPIRES_IN="8h"
PORT=3002
ADMIN_EMAIL="admin@justtime.co"
ADMIN_PASSWORD="Admin123!"
ADMIN_NAME="Administrador CMS"
CORS_ORIGIN="http://localhost:5173"

# Media: si GCS_BUCKET está definido, sube a Cloud Storage (prod).
# Sin bucket → disco local ./uploads (dev).
# GCS_BUCKET=just-time-media-prod
# GCS_PROJECT_ID=just-time-sas
# GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/just-time-media-prod
# GCS_KEY_FILE=./secrets/firebase-adminsdk.json

# Firebase Admin (notificaciones realtime → Firestore).
# Opción A (recomendada): ruta a JSON del service account
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-adminsdk.json
FIREBASE_PROJECT_ID=your-project-id

# Opción B: variables sueltas (FIREBASE_PRIVATE_KEY con \n escapados)
# FIREBASE_CLIENT_EMAIL=your-service-account@example.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Reglas Firestore sugeridas (colección admin_notifications):
#   match /admin_notifications/{id} {
#     allow read, update: if request.auth != null;
#     allow create, delete: if false;
#   }

